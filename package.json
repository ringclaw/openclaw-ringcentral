{
  "name": "openclaw-ringcentral",
  "version": "2026.7.8",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "RingCentral Team Messaging for OpenClaw with DM, Team, Group DM, and artifact tools",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pack:check": "node scripts/verify-package.mjs",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:live:ringcentral": "RC_E2E_REQUIRED=true vitest run src/live/ringcentral-live.test.ts --testTimeout=60000",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ringclaw/openclaw-ringcentral.git"
  },
  "homepage": "https://github.com/ringclaw/openclaw-ringcentral#readme",
  "keywords": ["openclaw", "ringcentral", "team-messaging", "chat", "bot"],
  "files": ["dist", "openclaw.plugin.json", "README.md", "LICENSE"],
  "openclaw": {
    "extensions": ["./index.ts"],
    "runtimeExtensions": ["./dist/index.js"],
    "channel": {
      "id": "ringcentral",
      "label": "RingCentral",
      "selectionLabel": "RingCentral Team Messaging",
      "detailLabel": "RingCentral",
      "docsPath": "/channels/ringcentral",
      "docsLabel": "ringcentral",
      "blurb": "RingCentral Team Messaging via REST API and WebSocket.",
      "aliases": ["rc", "ringcentral-tm"],
      "order": 56
    },
    "setupEntry": "./setup-entry.ts",
    "runtimeSetupEntry": "./dist/setup-entry.js",
    "install": {
      "npmSpec": "openclaw-ringcentral",
      "defaultChoice": "npm"
    },
    "compat": {
      "pluginApi": ">=2026.5.28"
    },
    "build": {
      "openclawVersion": "2026.5.28"
    }
  },
  "dependencies": {
    "typebox": "^1.1.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "openclaw": "2026.5.28",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.28"
  }
}
