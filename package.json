{
  "name": "openclaw-ringcentral",
  "version": "2026.4.0",
  "type": "module",
  "main": "index.ts",
  "description": "OpenClaw RingCentral Team Messaging channel plugin",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ringclaw/openclaw-ringcentral.git"
  },
  "homepage": "https://github.com/ringclaw/openclaw-ringcentral#readme",
  "keywords": ["openclaw", "ringcentral", "team-messaging", "chat", "bot"],
  "files": ["src", "index.ts", "openclaw.plugin.json", "README.md"],
  "openclaw": {
    "extensions": ["./index.ts"],
    "channel": {
      "id": "ringcentral",
      "label": "RingCentral",
      "selectionLabel": "RingCentral Team Messaging",
      "detailLabel": "RingCentral",
      "docsPath": "/channels/ringcentral",
      "docsLabel": "ringcentral",
      "blurb": "RingCentral Team Messaging via REST API and WebSocket.",
      "aliases": ["rc", "ringcentral-tm"],
      "order": 56
    },
    "setupEntry": "./setup-entry.ts",
    "install": {
      "npmSpec": "openclaw-ringcentral",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "openclaw": "2026.2.23",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.23"
  }
}
